#!/usr/bin/python3
from sys import argv
import json
import csv

# Convert json to csv
def json_to_csv(json_str, output="output.csv"):
    data = json.loads(json_str) if isinstance(json_str, str) else json_str

    # Flattens each dict into a row
    def flatten(obj, path=""):
        if isinstance(obj, dict):
            # Names the csv values as the json path joined with a "__"
            return [{k if not path else f"{path}__{k}": v for k, v in obj.items() if not isinstance(v, (dict, list))}]

        # if the object is an array then don't bother with headers
        if isinstance(obj, list):
            return [r for item in obj for r in flatten(item, path)]

        # Something else!
        return [{path: obj}] if path else []

    rows = flatten(data)
    if not rows:
        return

    # Sort the headers to match the rows
    headers = sorted({k for row in rows for k in row})

    # Write it to the file
    with open(output, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, headers)
        w.writeheader()
        for row in rows:
            w.writerow({h: row.get(h, "") for h in headers})

# Main
if __name__ == "__main__":
    if len(argv) != 3:
        print(f"{argv[0]} <json file> <output csv>")
        quit()

    # Load JSON file
    with open (argv[1]) as f:
        data = json.load(f)

        # Convert to CSV
        json_to_csv(data, argv[2])
        print(f"Converted {argv[1]} JSON, to {argv[2]} CSV")
